# ── Merchant ───────────────────────────────────────
MERCHANT_WALLET=0xYOUR_WALLET_ADDRESS
PORT=4021

# ── x402 Facilitator ──────────────────────────────
# Use x402.org for testnet (no signup needed)
# Use https://api.cdp.coinbase.com/platform/v2/x402 for production
FACILITATOR_URL=https://x402.org/facilitator

# ── XMTP (@xmtp/agent-sdk) ────────────────────────
XMTP_ENV=dev
XMTP_WALLET_KEY=0x_YOUR_WALLET_PRIVATE_KEY
XMTP_DB_ENCRYPTION_KEY=0x_64_HEX_CHARS_32_BYTES
XMTP_RECIPIENT_ADDRESS=0xRECIPIENT_ADDRESS
