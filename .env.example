# ── Merchant ───────────────────────────────────────
MERCHANT_WALLET=0xYOUR_WALLET_ADDRESS
PORT=3000

# ── Coinbase x402 ──────────────────────────────────
# CDP API Key for payment verification/settlement
CDP_API_KEY_ID=your_cdp_key_id
CDP_API_KEY_SECRET=your_cdp_key_secret

# ── World ID ───────────────────────────────────────
WORLD_APP_ID=app_your_app_id
WORLD_ACTION_ID=your_action_id

# ── XMTP ───────────────────────────────────────────
# Private key (hex) for the XMTP sender identity
XMTP_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
# Default recipient for audit messages
XMTP_RECIPIENT_ADDRESS=0xRECIPIENT_ADDRESS
