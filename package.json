{
  "name": "agentic-checkout",
  "version": "1.0.0",
  "description": "Headless merchant template for the agentic economy — x402 payments, World ID verification, XMTP audit rail.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["x402", "worldid", "xmtp", "agentic", "checkout"],
  "license": "MIT",
  "dependencies": {
    "x402-express": "^0.1.0",
    "better-sqlite3": "^11.0.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "nanoid": "^3.3.7"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.0"
  }
}
