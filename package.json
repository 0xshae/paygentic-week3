{
  "name": "repgate",
  "version": "1.0.0",
  "description": "Reputation-gated API gateway for the agent economy. Agents stake USDC via Locus Checkout and earn lower rates through successful API usage.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "demo:agent-a": "bash scripts/demo-agent-a.sh",
    "demo:agent-b": "bash scripts/demo-agent-b.sh",
    "seed:agent-b": "bash scripts/seed-agent-b.sh"
  },
  "keywords": [
    "reputation",
    "api-gateway",
    "locus",
    "checkout",
    "usdc",
    "agent",
    "staking"
  ],
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.0"
  }
}
